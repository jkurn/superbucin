# Supabase (get these from your Supabase project dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_POSTHOG_KEY=phc_your_project_api_key_here
# EU cloud: https://eu.i.posthog.com — US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Optional; matches PostHog install snippet
VITE_POSTHOG_DEFAULTS=2026-01-30
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
LOG_LEVEL=info
