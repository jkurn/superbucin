{
  "name": "superbucin",
  "version": "1.0.0",
  "description": "SUPERBUCIN — A couples minigame collection",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npx vite --host",
    "dev:server": "cd server && node index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd server && npm install && cd ../client && npm install && npx vite build",
    "start": "cd server && node index.js",
    "test": "node --test server/games/*/GameState.test.js server/rooms/RoomManager.test.js server/services/UserService.test.js client/src/shared/NetworkManager.test.js",
    "test:coverage": "node --experimental-test-coverage --test server/games/*/GameState.test.js server/rooms/RoomManager.test.js server/services/UserService.test.js client/src/shared/NetworkManager.test.js",
    "lint": "eslint client/src/ server/",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "{client/src,server}/**/*.js": "eslint --fix"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
